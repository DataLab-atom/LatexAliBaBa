% 图3：系统架构——Planner + MCP 工具层 + MOLE1（简洁版）
\begin{tikzpicture}[font=\small, node distance=0.45cm and 0.5cm]

% ── 第一层：输入 ──────────────────────────────────────────────────────────────
\node[box=10.2cm, minimum height=0.65cm] (input)
  {输入故障事件：告警 + 日志};

% ── 第二层：云端 Planner ──────────────────────────────────────────────────────
\node[greybox=10.2cm, minimum height=1.05cm, below=0.45cm of input] (planner)
  {\textbf{云端 LLM Planner（72B）}\quad
   {\footnotesize\itshape\textcolor{black!50}{延迟 $\sim$500\,ms}}\\[2pt]
   \footnotesize 分解故障事件 $\to$ 路由至对应 MCP 工具端点};

% ── 第三层标签 ────────────────────────────────────────────────────────────────
\node[below=0.45cm of planner, font=\small\bfseries] (mcplabel)
  {本地 MCP 工具层\enspace{\normalfont\footnotesize\itshape\textcolor{black!50}{延迟 $<$100\,ms}}};

% ── 第三层：MCP 工具端点 ──────────────────────────────────────────────────────
\node[box=2.6cm, minimum height=1.05cm, below=0.3cm of mcplabel] (t1)
  {\textbf{数据库故障}\\SLM\,(1.5B)};
\node[box=2.6cm, minimum height=1.05cm, right=0.4cm of t1] (t2)
  {\textbf{网络分区}\\SLM\,(4B)};
\node[box=2.6cm, minimum height=1.05cm, right=0.4cm of t2] (t3)
  {\textbf{容器资源耗尽}\\SLM\,(1.5B)};
\node[box=1.2cm, minimum height=1.05cm, right=0.4cm of t3,
      draw=black!30, text=black!40] (tdot)
  {\ldots\\新域};

% ── 第四层：MOLE1 离线生产（居中对齐 planner） ───────────────────────────────
\node[box=10.2cm, minimum height=0.82cm]
  at ([yshift=-1.05cm]t2.south -| planner.center) (mole)
  {\textbf{离线生产流水线：}
   C1 数据采集+CoT合成 $\;\to\;$
   C2 SFT $\;\to\;$
   C3 AIOps-GRPO $\;\to\;$ MCP 封装};

% ── 运行时箭头：输入 → Planner ────────────────────────────────────────────────
\draw[arrow] (input) -- (planner);

% ── 运行时箭头：Planner → MCP 工具端点 ───────────────────────────────────────
\draw[arrow] (planner.south) -- ++(0,-0.33) -| (t1.north);
\draw[arrow] (planner.south) -- ++(0,-0.33) -| (t2.north);
\draw[arrow] (planner.south) -- ++(0,-0.33) -| (t3.north);

% ── 离线生产虚线箭头：MOLE1 → MCP 工具端点 ───────────────────────────────────
\draw[dasharrow] (mole.north) -- ++(0,0.3) -| (t1.south);
\draw[dasharrow] (mole.north) -- ++(0,0.3) -| (t2.south);
\draw[dasharrow] (mole.north) -- ++(0,0.3) -| (t3.south);

% ── 图例 ─────────────────────────────────────────────────────────────────────
\node[below=0.3cm of mole, align=left, font=\footnotesize] {%
  $\longrightarrow$ 运行时调用\qquad
  $\dashrightarrow$ 专家小智能体离线生产（三循环流水线）};

\end{tikzpicture}
