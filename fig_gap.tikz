% 图1：研究空白对比——现有方法 vs 本方案（简洁版）
\begin{tikzpicture}[node distance=0.32cm and 1.1cm, font=\small]

\def\bw{4.9cm}

% ── 左列标题 ─────────────────────────────────────────────────────────────────
\node[box=\bw, minimum height=0.65cm, fill=black!10] (lh)
  {\textbf{现有 SLM 生产方法}};

% ── 左列三项强制前提 ───────────────────────────────────────────────────────────
\node[greybox=\bw, minimum height=0.65cm, below=0.3cm of lh] (e1)
  {人工标注 CoT（昂贵、缓慢）};
\node[greybox=\bw, minimum height=0.65cm, below=0.2cm of e1] (e2)
  {具领域知识的教师 LLM};
\node[greybox=\bw, minimum height=0.65cm, below=0.2cm of e2] (e3)
  {已有学生模型（先有鸡先有蛋）};

\node[below=0.18cm of e3, font=\footnotesize\itshape, text=black!55] (en)
  {冷启动时三者均不可得};

\node[box=\bw, minimum height=0.72cm, below=0.14cm of en,
      fill=black!18, draw=black!55] (efail)
  {$\times$\enspace\textbf{流水线无法启动}};

% ── 右列标题 ─────────────────────────────────────────────────────────────────
\node[box=\bw, minimum height=0.65cm, fill=black!10, right=1.1cm of lh] (rh)
  {\textbf{本方案}};

% ── 右列 MOLE1 路径 ────────────────────────────────────────────────────────────
\node[greybox=\bw, minimum height=0.65cm, below=0.3cm of rh] (m1)
  {原始 $\langle$查询, 答案$\rangle$ 对（来自日志）};
\node[greybox=\bw, minimum height=0.65cm, below=0.2cm of m1] (m2)
  {14B 教师生成 $k$ 条候选 CoT 推理链};
\node[greybox=\bw, minimum height=0.65cm, below=0.2cm of m2] (m3)
  {\textbf{标准答案}作为验证器，自动过滤};

\node[box=\bw, minimum height=0.72cm, below=0.5cm of m3,
      fill=black!4, draw=black!55] (mok)
  {$\checkmark$\enspace\textbf{无需标注，自动产出专家 SLM}};

\draw[arrow] (m1) -- (m2);
\draw[arrow] (m2) -- (m3);
\draw[arrow] (m3.south) -- (mok.north);

% ── 列头上方标签 ──────────────────────────────────────────────────────────────
\node[above=0.15cm of lh, font=\small\bfseries] {已有工作};
\node[above=0.15cm of rh, font=\small\bfseries] {本工作};

% ── 竖向分隔线 ────────────────────────────────────────────────────────────────
\draw[thick, dashed, black!35]
  ($(lh.north east)!0.5!(rh.north west)+(0,0.4)$) --
  ($(efail.south east)!0.5!(mok.south west)+(0,-0.15)$);

\end{tikzpicture}
